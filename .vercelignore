!frontend/
!frontend/**

# Ignore Ethereum/Hardhat files
contracts/
scripts/
test/
hardhat.config.js
cache/

# Ignore bot files
bot/

# Ignore development files
.gitignore
.env.example
.env
node-installer.msi

# Ignore documentation that's not needed for deployment
README.md
SETUP_GUIDE.md
STAGENET_DEPLOYMENT_GUIDE.md
FRONTEND_CODE.md

# Ignore root package files (we use frontend/package.json)
package.json
package-lock.json

# Ignore VS Code settings
.vscode/

# Ignore any other development files
*.log
*.tmp
.DS_Store
